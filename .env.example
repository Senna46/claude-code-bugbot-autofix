# ============================================================
# Fixooly Configuration
# ============================================================

# GitHub App ID (required)
# Obtain from your GitHub App settings page
AUTOFIX_APP_ID=

# GitHub App Private Key (one of these is required)
# Path to a .pem file downloaded from your GitHub App settings
AUTOFIX_PRIVATE_KEY_PATH=
# Or set the key content directly (useful in Docker/CI)
# AUTOFIX_PRIVATE_KEY=

# Polling interval in seconds (default: 120)
AUTOFIX_POLL_INTERVAL=120

# Working directory for cloned repos (default: ~/.fixooly/repos)
AUTOFIX_WORK_DIR=

# SQLite database path (default: ~/.fixooly/state.db)
AUTOFIX_DB_PATH=

# Claude model override (optional, uses default if empty)
AUTOFIX_CLAUDE_MODEL=

# Log level: debug, info, warn, error (default: info)
AUTOFIX_LOG_LEVEL=info

# ============================================================
# AI Authentication
# ============================================================

# Claude Code OAuth token (required on macOS Docker)
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Or use Anthropic API key for pay-as-you-go
ANTHROPIC_API_KEY=
